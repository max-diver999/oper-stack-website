---
import CommercialLayout from '../../components/CommercialLayout.astro';
import CitabilityBlock from '../../components/CitabilityBlock.astro';
import FaqSection from '../../components/FaqSection.astro';
import { PRICING_TIERS, PRICING_FAQ, PRICING_INCLUDES } from '../../data/pricing';
import { NETWORK_TOTALS, CASES_PERIOD } from '../../data/cases';
import { SITE } from '../../data/site';

const canonical = `${SITE.url}/pricing/`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: PRICING_FAQ.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<CommercialLayout
  title={`Pricing · ${SITE.name}`}
  description="OperStack pricing: free Lead Gen audit, custom setup, and retainer for inbound lead operations."
  canonical={canonical}
  jsonLd={faqSchema}
>
  <div class="wrap wide">
    <h1>Pick your entry point</h1>
    <p class="lede">
      Start with a free audit, launch a focused stack, or keep growth on retainer. Every plan runs through one Lead Hub.
    </p>

    <CitabilityBlock
      text="OperStack pricing starts with a free inbound stack audit, then custom setup and retainer quotes for teams that run on lead gen."
    />

    <div class="tiers">
      {PRICING_TIERS.map((tier) => (
        <article class:list={['tier', { featured: tier.featured }]}>
          {tier.featured && <span class="badge">Most teams start here</span>}
          <h2>{tier.name}</h2>
          <p class="tagline">{tier.tagline}</p>
          <p class="price">{tier.price}</p>
          {tier.priceNote && <p class="price-note">{tier.priceNote}</p>}
          <ul>
            {tier.features.map((f) => (
              <li>{f}</li>
            ))}
          </ul>
          <a class="btn" href={tier.href}>{tier.cta} →</a>
        </article>
      ))}
    </div>

    <aside class="proof-cta" aria-label="Client outcomes">
      <div class="proof-copy">
        <p class="proof-eyebrow">Verified portfolio metrics</p>
        <p class="proof-stat">
          {NETWORK_TOTALS.gscClicks.toLocaleString('en-GB')} GSC clicks ({NETWORK_TOTALS.gscClicksDelta}) across {NETWORK_TOTALS.liveSites} live inbound brands
        </p>
        <p class="proof-note">
          Anonymized case snapshots from Google Search Console and GA4 · {CASES_PERIOD.current}
        </p>
      </div>
      <a class="btn proof-btn" href="/cases/?utm=pricing-proof">See proof → Cases</a>
    </aside>

    <section class="includes">
      <h2>What every plan includes</h2>
      <ul>
        {PRICING_INCLUDES.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="guides-cta">
      <h2>Not sure which module you need?</h2>
      <p>Read the system map on the homepage or start with our lead ops guides.</p>
      <p style="margin-top:16px">
        <a class="btn btn-ghost" href="/guides/">Browse guides</a>
      </p>
    </section>

    <FaqSection items={PRICING_FAQ} />
  </div>
</CommercialLayout>

<style>
  .tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: 32px 0 40px;
  }
  @media (max-width: 860px) {
    .tiers { grid-template-columns: 1fr; }
  }
  .tier {
    padding: 24px 22px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .tier.featured {
    border-color: rgba(61, 184, 169, 0.4);
    background: rgba(61, 184, 169, 0.06);
    box-shadow: 0 20px 50px -30px rgba(61, 184, 169, 0.35);
  }
  .badge {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal-soft);
  }
  .tier h2 {
    font-family: var(--fd);
    font-size: 22px;
    letter-spacing: -0.02em;
  }
  .tagline {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .price {
    font-family: var(--fd);
    font-size: 28px;
    color: var(--amber-soft);
    margin: 4px 0;
  }
  .price-note {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .tier ul {
    list-style: none;
    margin: 8px 0 16px;
    flex: 1;
  }
  .tier li {
    font-size: 13px;
    color: rgba(245, 242, 236, 0.82);
    padding-left: 16px;
    position: relative;
    margin-bottom: 8px;
  }
  .tier li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--teal);
  }
  .includes {
    margin: 40px 0;
    padding: 24px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.07);
  }
  .includes h2 {
    font-family: var(--fd);
    font-size: 22px;
    margin-bottom: 14px;
  }
  .includes ul {
    list-style: none;
    display: grid;
    gap: 10px;
  }
  .includes li {
    font-size: 14px;
    color: rgba(245, 242, 236, 0.85);
    padding-left: 18px;
    position: relative;
  }
  .includes li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--teal-soft);
  }
  .proof-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin: 0 0 40px;
    padding: 22px 24px;
    border-radius: 14px;
    border: 1px solid rgba(61, 184, 169, 0.28);
    background: linear-gradient(135deg, rgba(61, 184, 169, 0.1), rgba(232, 184, 74, 0.06));
  }
  .proof-eyebrow {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal-soft);
    margin-bottom: 8px;
  }
  .proof-stat {
    font-family: var(--fd);
    font-size: clamp(18px, 3vw, 22px);
    letter-spacing: -0.02em;
    color: var(--paper);
    max-width: 36ch;
    line-height: 1.25;
  }
  .proof-note {
    margin-top: 8px;
    font-size: 12px;
    color: var(--muted);
    max-width: 42ch;
  }
  .proof-btn {
    flex-shrink: 0;
    white-space: nowrap;
  }
  .guides-cta h2 {
    font-family: var(--fd);
    font-size: 22px;
    margin-bottom: 8px;
  }
  .guides-cta p {
    color: var(--muted);
    font-size: 15px;
  }
</style>
