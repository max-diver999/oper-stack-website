---
import { SITE } from '../../data/site';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Thank you · {SITE.name}</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600&family=Fraunces:wght@600&display=swap" rel="stylesheet" />
  <style>
    body {
      margin: 0; min-height: 100vh; display: grid; place-items: center;
      background: #0B1017; color: #F5F2EC; font-family: 'DM Sans', system-ui, sans-serif;
      padding: 24px; text-align: center;
    }
    h1 { font-family: 'Fraunces', Georgia, serif; font-size: 32px; margin-bottom: 12px; }
    p { color: #8B939E; max-width: 420px; margin: 0 auto 24px; line-height: 1.5; }
    a { color: #3DB8A9; }
  </style>
</head>
<body>
  <div>
    <h1>Request received</h1>
    <p>We will reply within one business day with next steps for your Lead Gen audit.</p>
    <p><a href="/">← Back to system map</a></p>
  </div>
</body>
</html>
