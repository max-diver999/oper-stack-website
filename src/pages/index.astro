---
// Full-page interactive system map (OperStack homepage)
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OperStack · The operating stack for inbound leads</title>
<meta name="description" content="OperStack: the operating stack for inbound leads. SEO, AEO, AI qualification, CRM, team training, reporting. Interactive system map.">
<link rel="canonical" href="https://oper-stack.com/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style is:global>
  :root {
    --ink: #0B1017;
    --ink-soft: #141C28;
    --paper: #F5F2EC;
    --teal: #1A8A7D;
    --teal-soft: #3DB8A9;
    --teal-glow: rgba(61, 184, 169, 0.55);
    --amber: #C9922A;
    --amber-soft: #E8B84A;
    --amber-glow: rgba(232, 184, 74, 0.45);
    --muted: #8B939E;
    --fd: 'Fraunces', Georgia, serif;
    --fb: 'DM Sans', system-ui, sans-serif;
    --fm: 'JetBrains Mono', ui-monospace, monospace;
    --label-halo:
      0 0 1px rgba(0, 0, 0, 1),
      0 1px 3px rgba(0, 0, 0, 0.95),
      0 0 14px rgba(0, 0, 0, 0.85),
      0 0 28px rgba(0, 0, 0, 0.55);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    height: 100%;
    background: var(--ink);
    overflow: hidden;
    font-family: var(--fb);
    color: var(--paper);
  }

  #flow {
    position: fixed;
    inset: 0;
    display: block;
    transition: filter 0.5s ease;
  }

  #layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    background: radial-gradient(130% 95% at 50% 45%, transparent 38%, rgba(5, 8, 12, 0.72) 100%);
  }

  .hud {
    position: fixed;
    z-index: 6;
    left: 0;
    right: 0;
    top: 0;
    padding: 36px 44px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    pointer-events: none;
    transition: opacity 0.4s;
  }

  .brand {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--teal-soft);
    margin-bottom: 14px;
  }

  .eyebrow {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .eyebrow .pip {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal-soft);
    box-shadow: 0 0 14px 1px var(--teal);
    animation: pip 2.4s ease-in-out infinite;
  }

  @keyframes pip {
    0%, 100% { opacity: 0.35; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1); }
  }

  h1 {
    margin-top: 12px;
    font-family: var(--fd);
    font-weight: 600;
    font-size: clamp(24px, 3.2vw, 46px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    max-width: 14ch;
    text-shadow: var(--label-halo);
  }

  h1 em {
    font-style: normal;
    color: var(--amber-soft);
  }

  .meta {
    text-align: right;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--muted);
    line-height: 2;
  }

  .meta b { color: var(--paper); font-weight: 500; }

  .legend {
    position: fixed;
    z-index: 6;
    left: 44px;
    bottom: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(235, 238, 242, 0.88);
    pointer-events: none;
    text-shadow: var(--label-halo);
  }

  .legend span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .legend .dot-core {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #fff, var(--teal-soft) 45%, var(--teal) 100%);
    box-shadow: 0 0 12px var(--teal-glow);
  }

  .legend .dot-mod {
    width: 10px;
    height: 10px;
    border-radius: 4px;
    background: linear-gradient(145deg, #1e2836, #0f141c);
    border: 1px solid rgba(61, 184, 169, 0.45);
  }

  .legend .dot-db {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    background: rgba(201, 146, 42, 0.25);
    border: 1px solid rgba(232, 184, 74, 0.5);
  }

  .hint {
    position: fixed;
    z-index: 6;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(235, 238, 242, 0.82);
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 8px;
    text-shadow: var(--label-halo);
  }

  .hint .d {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--teal-soft);
    box-shadow: 0 0 8px var(--teal-glow);
  }

  #core {
    position: absolute;
    width: 108px;
    height: 108px;
    transform: translate(-50%, -50%);
    will-change: transform;
    pointer-events: auto;
    cursor: pointer;
  }

  .ball {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s;
    background: radial-gradient(circle at 32% 26%, #5a9e96 0%, #1a5c54 28%, #0a1512 62%, #030605 100%);
    box-shadow:
      inset -8px -10px 22px rgba(0, 0, 0, 0.85),
      inset 6px 6px 16px rgba(180, 240, 230, 0.12),
      0 22px 50px -12px rgba(0, 0, 0, 0.75),
      0 0 40px -8px var(--teal-glow);
  }

  #core:hover .ball,
  #core.sel .ball {
    transform: scale(1.07);
    box-shadow:
      inset -8px -10px 22px rgba(0, 0, 0, 0.85),
      inset 6px 6px 16px rgba(180, 240, 230, 0.18),
      0 0 70px -4px var(--teal-glow),
      0 22px 50px -12px rgba(0, 0, 0, 0.75);
  }

  .ball::after {
    content: "";
    position: absolute;
    top: 12%;
    left: 18%;
    width: 38%;
    height: 28%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 250, 240, 0.55), transparent 72%);
    filter: blur(2px);
  }

  .disc {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 48px;
    height: 48px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle at 40% 34%, #fff, #e8f5f2);
    box-shadow: inset 0 -3px 5px rgba(0, 0, 0, 0.18);
    display: grid;
    place-items: center;
  }

  .disc span {
    font-family: var(--fd);
    font-weight: 700;
    font-size: 22px;
    color: var(--ink);
    line-height: 1;
  }

  .core-cap {
    position: absolute;
    top: 118px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal-soft);
    text-shadow: var(--label-halo);
  }

  .node {
    position: absolute;
    transform: translate(-50%, -50%);
    will-change: transform;
    pointer-events: auto;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    width: 132px;
    transition: opacity 0.45s ease;
    z-index: 2;
    --lift: 0;
  }

  .node.near,
  .node.active {
    z-index: 5;
  }

  .node:hover .avatar,
  .node.active .avatar,
  .node.near .avatar {
    transform: translateY(calc(-4px - var(--lift, 0) * 6px)) scale(calc(1.04 + var(--lift, 0) * 0.06));
    border-color: rgba(61, 184, 169, calc(0.45 + var(--lift, 0) * 0.35));
    box-shadow: 0 18px 40px -12px rgba(61, 184, 169, calc(0.25 + var(--lift, 0) * 0.45));
  }

  .avatar {
    position: relative;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(158deg, #1a2430, #0d1218);
    border: 1px solid rgba(61, 184, 169, 0.28);
    box-shadow: 0 12px 28px -10px rgba(0, 0, 0, 0.72), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    display: grid;
    place-items: center;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.4s, box-shadow 0.4s;
  }

  .avatar svg {
    width: 26px;
    height: 26px;
    stroke: var(--teal-soft);
    stroke-width: 1.6;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .avatar .status {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--amber-soft);
    border: 2px solid var(--ink);
    box-shadow: 0 0 8px var(--amber-glow);
  }

  .avatar .status::after {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 1.5px solid var(--amber-soft);
    animation: ring2 2.6s ease-out infinite;
  }

  @keyframes ring2 {
    0% { transform: scale(0.6); opacity: 0.9; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  .node .name {
    font-family: var(--fd);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: -0.01em;
    text-align: center;
    line-height: 1.18;
    color: #fff;
    max-width: 128px;
    text-shadow: var(--label-halo);
    -webkit-font-smoothing: antialiased;
  }

  .node .role {
    font-family: var(--fm);
    font-size: 8px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: rgba(190, 200, 210, 0.95);
    margin-top: -2px;
    text-align: center;
    max-width: 128px;
    line-height: 1.25;
    text-shadow: var(--label-halo);
    opacity: 1;
    transform: translateY(0);
    pointer-events: none;
  }

  .node.near .name,
  .node:hover .name,
  .node.active .name {
    color: #fff;
  }

  .node.dim { opacity: 0.2; }

  .node.custom .avatar {
    border-style: dashed;
    border-color: rgba(232, 184, 74, 0.45);
    background: linear-gradient(158deg, rgba(30, 28, 22, 0.6), rgba(14, 16, 12, 0.7));
  }

  .node.custom .avatar svg {
    stroke: var(--amber-soft);
    animation: plusPulse 2.8s ease-in-out infinite;
  }

  .node.custom .name { color: var(--amber-soft); }
  .node.custom .status { display: none; }

  .node.train .avatar {
    border-color: rgba(232, 184, 74, 0.42);
    background: linear-gradient(158deg, #2a2418, #14120e);
  }

  .node.train .avatar svg { stroke: var(--amber-soft); }

  .node.train.near .avatar,
  .node.train:hover .avatar,
  .node.train.active .avatar {
    border-color: rgba(232, 184, 74, calc(0.55 + var(--lift, 0) * 0.35));
    box-shadow: 0 18px 40px -12px rgba(232, 184, 74, calc(0.2 + var(--lift, 0) * 0.4));
  }

  .node.train .name { color: #F5E8C8; }

  @keyframes plusPulse {
    0%, 100% { opacity: 0.55; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.08); }
  }

  .db {
    position: absolute;
    transform: translate(-50%, -50%);
    will-change: transform, opacity;
    pointer-events: auto;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    width: 72px;
    transition: opacity 0.45s ease;
    z-index: 1;
    --lift: 0;
  }

  .db.near,
  .db.sel {
    z-index: 4;
  }

  .db:hover .cyl,
  .db.sel .cyl,
  .db.near .cyl {
    transform: scale(calc(1.1 + var(--lift, 0) * 0.12));
    border-color: rgba(232, 184, 74, calc(0.75 + var(--lift, 0) * 0.25));
    box-shadow: 0 10px 22px -8px rgba(232, 184, 74, calc(0.35 + var(--lift, 0) * 0.35));
  }

  .db .cyl {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(201, 146, 42, 0.18);
    border: 1px solid rgba(232, 184, 74, 0.38);
    display: grid;
    place-items: center;
    box-shadow: 0 6px 16px -8px rgba(0, 0, 0, 0.6);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.35s, box-shadow 0.35s;
  }

  .db .cyl svg {
    width: 15px;
    height: 15px;
    stroke: var(--amber-soft);
    stroke-width: 1.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .db .dn {
    font-family: var(--fm);
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(240, 232, 210, 0.96);
    text-align: center;
    line-height: 1.2;
    max-width: 76px;
    text-shadow: var(--label-halo);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  .db.near .dn,
  .db:hover .dn,
  .db.sel .dn,
  .db.lit .dn {
    opacity: 1;
    transform: translateY(0);
  }

  .db.dim { opacity: 0.1; }

  .dim-overlay {
    position: fixed;
    inset: 0;
    z-index: 7;
    background: rgba(6, 9, 14, 0.48);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s, visibility 0.4s;
    backdrop-filter: blur(2px);
  }

  .dim-overlay.show { opacity: 1; visibility: visible; }

  .panel {
    position: fixed;
    z-index: 8;
    top: 0;
    right: 0;
    height: 100%;
    width: min(480px, 94vw);
    background: linear-gradient(180deg, rgba(18, 26, 36, 0.98), rgba(10, 14, 20, 0.99));
    border-left: 1px solid rgba(61, 184, 169, 0.22);
    box-shadow: -30px 0 80px -30px rgba(0, 0, 0, 0.85);
    transform: translateX(102%);
    transition: transform 0.5s cubic-bezier(0.2, 0.85, 0.25, 1);
    padding: 44px 38px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .panel.show { transform: translateX(0); }

  .panel .close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 18px;
    display: grid;
    place-items: center;
    transition: all 0.25s;
  }

  .panel .close:hover {
    border-color: var(--teal-soft);
    color: var(--paper);
    transform: rotate(90deg);
  }

  .panel .p-head {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 4px;
  }

  .panel .p-ava {
    width: 58px;
    height: 58px;
    border-radius: 16px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    background: linear-gradient(158deg, #1e2836, #101820);
    border: 1px solid rgba(61, 184, 169, 0.32);
  }

  .panel .p-ava svg {
    width: 28px;
    height: 28px;
    stroke: var(--teal-soft);
    stroke-width: 1.6;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .panel .p-ava.core {
    background: #0a1210;
    border-color: rgba(255, 255, 255, 0.18);
  }

  .panel .p-ava.core .b8 {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, #fff, #e8f5f2);
    display: grid;
    place-items: center;
    font-family: var(--fd);
    font-weight: 700;
    color: var(--ink);
    font-size: 18px;
  }

  .panel .p-title {
    font-family: var(--fd);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .panel .p-role {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-soft);
    margin-top: 4px;
  }

  .panel .p-lede {
    font-size: 15px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.82);
  }

  .proof-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 100px;
    background: rgba(61, 184, 169, 0.1);
    border: 1px solid rgba(61, 184, 169, 0.25);
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--teal-soft);
    width: fit-content;
  }

  .sect .lbl {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 12px;
  }

  .sect .lbl::before {
    content: "";
    width: 18px;
    height: 2px;
    background: var(--teal-soft);
  }

  .sect.feeds .lbl::before { background: var(--amber-soft); }

  .sect ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .sect li {
    font-size: 14px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    padding-left: 20px;
    position: relative;
  }

  .sect li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--teal);
    box-shadow: 0 0 8px var(--teal-glow);
  }

  .feeds .dbs { display: flex; flex-direction: column; gap: 8px; }

  .feeds .chip {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 13px;
    border-radius: 11px;
    background: rgba(201, 146, 42, 0.12);
    border: 1px solid rgba(232, 184, 74, 0.28);
    font-size: 13px;
  }

  .feeds .chip svg {
    width: 16px;
    height: 16px;
    stroke: var(--amber-soft);
    stroke-width: 1.5;
    fill: none;
    flex-shrink: 0;
  }

  .feeds .chip b { font-weight: 600; }
  .feeds .chip span {
    margin-left: auto;
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .p-foot {
    font-size: 13px;
    line-height: 1.55;
    color: var(--muted);
    padding-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .p-foot b { color: rgba(255, 255, 255, 0.85); }

  .p-cta {
    margin-top: auto;
    padding-top: 16px;
  }

  .p-cta a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--teal), #156b62);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    box-shadow: 0 10px 32px -8px var(--teal-glow);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .p-cta a:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px -8px var(--teal-glow);
  }

  body.panel-open .hud,
  body.panel-open .hint,
  body.panel-open .legend { opacity: 0; }

  body.panel-open #flow { filter: blur(3px) brightness(0.72); }

  /* ── Mobile: list + focus zone (variant C) ── */
  .mob-list {
    display: none;
  }

  body.is-mobile {
    overflow: hidden;
  }

  body.is-mobile #flow,
  body.is-mobile #layer,
  body.is-mobile .vignette {
    bottom: auto;
    height: var(--map-h, 42vh);
  }

  body.is-mobile .hud {
    padding: 14px 18px 6px;
    pointer-events: none;
  }

  body.is-mobile h1 {
    font-size: 21px;
    max-width: 18ch;
    margin-top: 8px;
  }

  body.is-mobile .brand { margin-bottom: 8px; font-size: 9px; }
  body.is-mobile .meta,
  body.is-mobile .legend,
  body.is-mobile .hint { display: none; }

  body.is-mobile .mob-list {
    display: flex;
    flex-direction: column;
    position: fixed;
    left: 0;
    right: 0;
    top: var(--map-h, 42vh);
    bottom: 0;
    z-index: 10;
    background: linear-gradient(180deg, #121a24 0%, var(--ink) 12%);
