  const DB = '<path d="M4 6c0-1.4 3.6-2.5 8-2.5s8 1.1 8 2.5-3.6 2.5-8 2.5S4 7.4 4 6zM4 6v12c0 1.4 3.6 2.5 8 2.5s8-1.1 8-2.5V6M4 12c0 1.4 3.6 2.5 8 2.5s8-1.1 8-2.5"/>';

  function dbShort(full) {
    const map = {
      "Google Search Console": "GSC",
      "MDX content repo": "MDX",
      "IndexNow / Bing": "IndexNow",
      "WhatsApp / Telegram": "WA / TG",
