      lede: "Site publishes once. Telegram, LinkedIn, X pull from the same source. No duplicate manual work.",
      does: ["RSS hub from site", "Scheduled crosspost", "Platform-native formatting", "CTA back to site"],
      feeds: [
        ["Site RSS", "source", "Blog and news feed.", ["New posts"]],
        ["LinkedIn / X", "channels", "B2B distribution.", ["Scheduled posts"]],
        ["Telegram", "alerts", "Fast signals to audience.", ["Digest messages"]]
      ]
    },
    {
      key: "news", name: "News + Shorts", role: "signal layer", proof: "pipeline v2",
      lede: "Curated AI and industry news with commentary. Auto digest to site and social. Shorts when video is ready.",
      does: ["Perplexity + Claude digest", "Weekly publish batch", "Filters noise, adds opinion", "Feeds SEO freshness"],
      feeds: [
        ["News sources", "input", "Curated links and RSS.", ["Raw items"]],
        ["Claude API", "editor", "Commentary and assembly.", ["Digest drafts"]],
        ["Blog MDX", "output", "Published news pages.", ["Live URLs"]]
      ]
    },
    {
      key: "train", name: "Team Training", role: "onboard · enable", proof: "AI paths · CRM gates",
      lede: "AI onboarding and training for new hires and ongoing enablement. Company intro, team, scripts, quizzes. Progress synced to CRM before live leads are assigned.",
      does: [
        "Turns PDFs, Notion, and Loom into role-based learning paths",
        "Onboard track (days 1 to 14) plus ongoing script and product updates",
        "Bot Q&A grounded in your knowledge base, not generic chat",
        "CRM gates: certified status before routing inbound leads"
      ],
      feeds: [
        ["Training library", "docs", "PDFs, Notion pages, playbooks, Loom and slide decks.", ["Lesson sources", "Version history"]],
        ["Call Analytics", "examples", "Real call snippets and QA notes for practice.", ["Transcript highlights", "Script gaps"]],
        ["Kommo CRM", "progress", "Onboarding stage, quiz scores, certification flags.", ["Completion %", "Ready for leads"]]
      ]
    },
    {
      key: "custom", name: "Your module", role: "custom build", custom: true,
      lede: "After the core stack is live, we add modules for your market: payments, listings, custom APIs, vertical logic.",
      does: ["Scoped to your workflow", "Same hub architecture", "Documented handoff", "Optional support plan"],
      feeds: [
        ["Your APIs", "data", "Any service with an endpoint.", ["Custom events"]],
        ["Your team", "process", "Humans in the loop where it matters.", ["Approval steps"]]
      ]
    }
  ];

  const CORE = {
    title: "Lead Hub",
    role: "routing · CRM · analytics",
    lede: "Single control point for every inbound lead. All modules read and write here. No lead lost between chat, site, CRM, and reports.",
    why: ["Routes every lead to the right stage", "Connects bots, site forms, and CRM", "Feeds reporting in real time", "Human override always available"],
    inside: [
      ["Lead routing", "who gets what"],
      ["Pipeline rules", "stages + tags"],
      ["Attribution", "source tracking"],
      ["SLA timers", "response targets"],
      ["Audit log", "what changed"],
      ["API layer", "integrations"]
    ]
  };

  function makeGlow(rgb) {
    const s = 48;
    const cv = document.createElement("canvas");
    cv.width = cv.height = s;
    const c = cv.getContext("2d");
    const g = c.createRadialGradient(s / 2, s / 2, 0, s / 2, s / 2, s / 2);
    g.addColorStop(0, rgba(rgb, 1));
    g.addColorStop(0.22, rgba(rgb, 0.5));
    g.addColorStop(1, rgba(rgb, 0));
    c.fillStyle = g;
    c.fillRect(0, 0, s, s);
    return cv;
  }

  const SPR = { teal: makeGlow(TEAL), amber: makeGlow(AMBER) };

  const S = {
    w: 0, h: 0, dpr: 1, last: 0, mobile: false, mobFocus: 0, mapH: 0,
    core: { x: 0, y: 0, r: 52, px: 0, py: 0 },
    active: null,
    ptr: { x: -9999, y: -9999, sx: -9999, sy: -9999, heat: 0, active: false },
    streams: [], dust: [], edges: [], bg: null
  };

  function buildMobList() {
    if (!mobScroll) return;
    mobScroll.innerHTML =
      `<button type="button" class="mob-item mob-hub" data-focus="hub">
        <span class="mob-ava hub"><span>H</span></span>
        <span class="mob-copy"><b>Lead Hub</b><small>routing · CRM · analytics</small></span>
      </button>
      <div class="mob-divider">Modules</div>` +
      MODULES.map((m, i) =>
        `<button type="button" class="mob-item" data-focus="${i}">
          <span class="mob-ava"><svg viewBox="0 0 24 24">${I[m.key]}</svg></span>
          <span class="mob-copy"><b>${m.name}</b><small>${m.role}${m.proof ? " · " + m.proof : ""}</small></span>
        </button>`
      ).join("");
    mobScroll.querySelectorAll(".mob-item").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn.dataset.focus === "hub") {
          setMobFocus(-1);
          openCore();
        } else {
          const i = +btn.dataset.focus;
          setMobFocus(i);
          openModule(i);
        }
      });
    });
    updateMobListActive();
  }

  function updateMobListActive() {
    if (!mobScroll) return;
    mobScroll.querySelectorAll(".mob-item").forEach((btn) => {
      const f = btn.dataset.focus;
      btn.classList.toggle("active", f === "hub" ? S.mobFocus < 0 : +f === S.mobFocus);
    });
  }

  function setMobFocus(i) {
    S.mobFocus = i;
    if (S.mobile) {
      layoutMobile(S.mapH);
      buildP();
    }
    updateMobListActive();
  }

  function clearMobClasses() {
    nodes.forEach((n) => n.el.classList.remove("mob-off", "mob-focus"));
    dbs.forEach((d) => d.el.classList.remove("mob-off", "mob-focus", "lit"));
  }

  function layoutMobile(mh) {
    const cx = S.w * 0.5;
    const cy = mh * 0.64;
    S.core.x = cx;
    S.core.y = cy;
    S.core.r = clamp(Math.min(S.w, mh) * 0.075, 30, 44);

    nodes.forEach((n, i) => {
      const on = S.mobFocus >= 0 && i === S.mobFocus;
      n.el.classList.toggle("mob-off", !on);
      n.el.classList.toggle("mob-focus", on);
      if (on) {
        n.tx = cx;
        n.ty = mh * 0.26;
        n.x = n.tx;
        n.y = n.ty;
        n.vx = 0;
        n.vy = 0;
      }
    });

    if (S.mobFocus < 0) {
      S.core.y = mh * 0.5;
    }
  }

  function layoutDesktopOrbit() {
    clearMobClasses();
    const N = nodes.length;
    const rad = clamp(Math.min(S.w, S.h) * 0.31, 185, 320);
    const padX = 110;
    const padTop = 125;
    const padBot = 100;

    nodes.forEach((n, i) => {
      n.angle = -Math.PI / 2 + (i / N) * TAU;
      const orbit = 0.78 + (i % 2) * 0.08;
      n.tx = clamp(S.core.x + Math.cos(n.angle) * rad * orbit * 1.2, padX, S.w - padX);
      n.ty = clamp(S.core.y + Math.sin(n.angle) * rad * orbit * 0.88, padTop, S.h - padBot);
      if (!n.x) { n.x = n.tx; n.y = n.ty; }
    });
  }

  function edgeVisible(e) {
    if (!S.mobile) return true;
    if (S.mobFocus < 0) return false;
    if (e.k === "core") {
      const mi = typeof e.a === "number" ? e.a : (typeof e.b === "number" ? e.b : -1);
      return mi === S.mobFocus;
    }
    if (e.db && e.a && e.a.db != null) return dbs[e.a.db].mi === S.mobFocus;
    return false;
  }

  const nodes = MODULES.map((m, i) => {
    const el = document.createElement("div");
    el.className = "node" + (m.custom ? " custom" : "") + (m.key === "train" ? " train" : "");
    el.innerHTML = `<div class="avatar">${m.custom ? "" : '<span class="status"></span>'}<svg viewBox="0 0 24 24">${I[m.key]}</svg></div>
      <div class="name">${m.name}</div><div class="role">${m.role}</div>`;
    el.addEventListener("click", () => openModule(i));
    layer.appendChild(el);
    return { ...m, el, x: 0, y: 0, tx: 0, ty: 0, vx: 0, vy: 0, phase: i * 1.41, angle: 0 };
  });

  const dbs = [];
  nodes.forEach((n, mi) => {
    const arr = MODULES[mi].feeds;
    arr.forEach((f, k) => {
      const el = document.createElement("div");
      el.className = "db";
      el.innerHTML = `<div class="cyl"><svg viewBox="0 0 24 24">${DB}</svg></div><div class="dn">${dbShort(f[0])}</div>`;
      const di = dbs.length;
      el.addEventListener("click", (ev) => { ev.stopPropagation(); openDB(di); });
      layer.appendChild(el);
      dbs.push({
        mi, el, x: 0, y: 0,
        spread: (k - (arr.length - 1) / 2) * 0.55,
        name: f[0], tag: f[1], lede: f[2], takes: f[3]
      });
    });
  });

  buildMobList();

  function buildEdges() {
    const n = nodes.length;
    const M = dbs.length;
    const E = [];
    for (let i = 0; i < n; i++) E.push({ k: "core", a: i, b: "core", seed: i * 2.1 });
    for (let i = 0; i < n; i++) E.push({ k: "ring", a: i, b: (i + 1) % n, ring: true, seed: i * 3.7 + 1 });
    for (let i = 0; i < n; i++) E.push({ k: "ring", a: i, b: (i + 2) % n, ring: true, seed: i * 5.1 + 2 });
    dbs.forEach((d, di) => E.push({ k: "db", a: { db: di }, b: d.mi, db: true, seed: di * 1.9 }));
    for (let i = 0; i < M; i++) E.push({ k: "web", a: { db: i }, b: { db: (i + 1) % M }, web: true, seed: i * 1.3 });
    for (let i = 0; i < M; i++) E.push({ k: "web", a: { db: i }, b: { db: (i + 4) % M }, web: true, seed: i * 1.7 + 9 });
    S.edges = E;
  }

  const pt = (ref) => ref === "core"
    ? { x: S.core.x + S.core.px, y: S.core.y + S.core.py }
    : (ref && ref.db != null ? dbs[ref.db] : nodes[ref]);

  const ownerOf = (ref) => (ref && ref.db != null) ? dbs[ref.db].mi : ref;
  const inActive = (e) => S.active === null ? true : (ownerOf(e.a) === S.active || ownerOf(e.b) === S.active);
  const edgeHot = (e) => S.active === null ? 1 : (inActive(e) ? 1.55 : 0.07);

  const dim = document.getElementById("dim");
  const panel = document.getElementById("panel");
  const $ = (id) => document.getElementById(id);

  function openModule(i) {
    const m = MODULES[i];
    S.active = i;
    if (S.mobile) {
      S.mobFocus = i;
      layoutMobile(S.mapH);
      updateMobListActive();
    }
    $("p-ava").className = "p-ava";
    $("p-ava").innerHTML = `<svg viewBox="0 0 24 24">${I[m.key]}</svg>`;
    $("p-title").textContent = m.name;
    $("p-role").textContent = m.role;
    $("p-lede").textContent = m.lede;
    const proof = $("p-proof");
    if (m.proof) {
      proof.hidden = false;
      proof.textContent = "Live proof · " + m.proof;
    } else {
      proof.hidden = true;
    }
    $("lblDoes").textContent = "What it does";
    $("lblFeeds").textContent = "Connected sources";
    $("p-does").innerHTML = m.does.map((d) => `<li>${d}</li>`).join("");
    $("p-feeds").innerHTML = m.feeds.map((f) =>
      `<div class="chip"><svg viewBox="0 0 24 24">${DB}</svg><b>${f[0]}</b><span>${f[1]}</span></div>`
    ).join("");
    $("p-foot").innerHTML = `<b>${m.name}</b> pulls from connected sources, processes through Lead Hub, and outputs measurable lead outcomes.`;
    cta(m.custom ? "Scope a custom module" : "Get this module", "mod-" + m.key);
    showPanel();
    coreEl.classList.remove("sel");
    nodes.forEach((n, j) => {
      n.el.classList.toggle("dim", j !== i);
      n.el.classList.toggle("active", j === i);
    });
    dbs.forEach((d) => {
      d.el.classList.toggle("dim", d.mi !== i);
      d.el.classList.remove("sel");
      d.el.classList.toggle("lit", d.mi === i);
    });
  }

  function openDB(di) {
    const d = dbs[di];
    const m = MODULES[d.mi];
    S.active = d.mi;
    if (S.mobile) {
      S.mobFocus = d.mi;
      layoutMobile(S.mapH);
      updateMobListActive();
    }
    $("p-ava").className = "p-ava";
    $("p-ava").innerHTML = `<svg viewBox="0 0 24 24" style="stroke:var(--amber-soft)">${DB}</svg>`;
    $("p-title").textContent = d.name;
    $("p-role").textContent = "source · " + m.name;
    $("p-lede").textContent = d.lede;
    $("p-proof").hidden = true;
    $("lblDoes").textContent = "Data used by module";
    $("lblFeeds").textContent = "Flow";
    $("p-does").innerHTML = d.takes.map((t) => `<li>${t}</li>`).join("");
    $("p-feeds").innerHTML =
      `<div class="chip"><svg viewBox="0 0 24 24">${I[m.key]}</svg><b>${m.name}</b><span>processes</span></div>` +
      `<div class="chip"><b>Lead Hub</b><span>stores</span></div>`;
    $("p-foot").innerHTML = `<b>${d.name}</b> → <b>${m.name}</b> → <b>Lead Hub</b>.`;
    cta("Connect your stack", "db-" + m.key);
    showPanel();
    coreEl.classList.remove("sel");
    nodes.forEach((n, j) => {
      n.el.classList.toggle("dim", j !== d.mi);
      n.el.classList.toggle("active", j === d.mi);
    });
    dbs.forEach((x, j) => {
      x.el.classList.toggle("dim", x.mi !== d.mi);
      x.el.classList.toggle("sel", j === di);
      x.el.classList.toggle("lit", x.mi === d.mi);
    });
  }

  function openCore() {
    S.active = "core";
    if (S.mobile) {
      S.mobFocus = -1;
      layoutMobile(S.mapH);
      updateMobListActive();
    }
    $("p-ava").className = "p-ava core";
    $("p-ava").innerHTML = `<div class="b8">H</div>`;
    $("p-title").textContent = CORE.title;
    $("p-role").textContent = CORE.role;
    $("p-lede").textContent = CORE.lede;
    $("p-proof").hidden = false;
    $("p-proof").textContent = "Battle-tested · live production stack";
    $("lblDoes").textContent = "Why the hub matters";
    $("lblFeeds").textContent = "What's inside";
    $("p-does").innerHTML = CORE.why.map((d) => `<li>${d}</li>`).join("");
    $("p-feeds").innerHTML = CORE.inside.map((f) =>
      `<div class="chip"><b>${f[0]}</b><span>${f[1]}</span></div>`
    ).join("");
    $("p-foot").innerHTML = "Change routing rules once. Every module stays in sync. <b>One hub, zero lead leakage.</b>";
    cta("Book a free Lead Gen audit", "core");
    showPanel();
    coreEl.classList.add("sel");
    nodes.forEach((n) => n.el.classList.remove("dim", "active"));
    dbs.forEach((d) => { d.el.classList.add("dim"); d.el.classList.remove("sel", "lit"); });
  }

  function cta(text, content) {
    $("p-cta-text").textContent = text;
    $("p-cta-link").href = "/audit/?utm=" + content;
  }

  function showPanel() {
    document.body.classList.add("panel-open");
    dim.classList.add("show");
    panel.classList.add("show");
    panel.setAttribute("aria-hidden", "false");
  }

  function closePanel() {
    S.active = null;
    document.body.classList.remove("panel-open");
    dim.classList.remove("show");
    panel.classList.remove("show");
    panel.setAttribute("aria-hidden", "true");
    coreEl.classList.remove("sel");
    nodes.forEach((n) => n.el.classList.remove("dim", "active"));
    dbs.forEach((d) => d.el.classList.remove("dim", "sel", "lit"));
  }

  coreEl.addEventListener("click", openCore);
  coreEl.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); openCore(); } });
  dim.addEventListener("click", closePanel);
  $("pclose").addEventListener("click", closePanel);
  addEventListener("keydown", (e) => { if (e.key === "Escape") closePanel(); });

  const TAU = Math.PI * 2;
  const mix = (a, b, p) => a + (b - a) * p;
  const ease3 = (p) => (p < 0.5 ? 4 * p * p * p : 1 - Math.pow(-2 * p + 2, 3) / 2);

  function bez(p0, p1, p2, p3, t) {
    const u = 1 - t, uu = u * u, tt = t * t;
    return {
      x: uu * u * p0.x + 3 * uu * t * p1.x + 3 * u * tt * p2.x + tt * t * p3.x,
      y: uu * u * p0.y + 3 * uu * t * p1.y + 3 * u * tt * p2.y + tt * t * p3.y
    };
  }

  function resize() {
    S.dpr = Math.min(devicePixelRatio || 1, 1.75);
    S.w = innerWidth;
    S.h = innerHeight;
    S.mobile = S.w < MOB_BP;
    document.body.classList.toggle("is-mobile", S.mobile);

    S.mapH = S.mobile ? clamp(S.h * 0.4, 260, 360) : S.h;
    document.documentElement.style.setProperty("--map-h", S.mapH + "px");

    const ch = S.mobile ? S.mapH : S.h;
    canvas.width = (S.w * S.dpr) | 0;
    canvas.height = (ch * S.dpr) | 0;
    canvas.style.width = S.w + "px";
    canvas.style.height = ch + "px";
    ctx.setTransform(S.dpr, 0, 0, S.dpr, 0, 0);

    if (S.mobile) {
      if (S.mobFocus === undefined) S.mobFocus = 0;
      layoutMobile(S.mapH);
    } else {
      S.core.x = S.w * 0.5;
      S.core.y = S.h * 0.54;
      S.core.r = clamp(Math.min(S.w, S.h) * 0.048, 36, 52);
      clearMobClasses();
      layoutDesktopOrbit();
      nodes.forEach((n) => { n.x = n.tx; n.y = n.ty; n.vx = 0; n.vy = 0; });
    }

    const bgR = Math.max(S.w, ch) * 0.72;
    const bg = ctx.createRadialGradient(S.core.x, S.core.y, 0, S.core.x, S.core.y, bgR);
    bg.addColorStop(0, rgba(TEAL, 0.18));
    bg.addColorStop(0.16, rgba(TEAL, 0.11));
    bg.addColorStop(0.38, rgba(AMBER, 0.06));
    bg.addColorStop(0.68, rgba(TEAL, 0.02));
    bg.addColorStop(1, "rgba(11, 16, 23, 0)");
    S.bg = bg;

    buildP();
    if (reduce) draw(1800, 0);
  }

  function placeDBs() {
    const mh = S.mapH || S.h;
    dbs.forEach((d) => {
      if (S.mobile) {
        if (S.mobFocus < 0 || d.mi !== S.mobFocus) {
          d.el.classList.add("mob-off");
          d.el.classList.remove("mob-focus", "lit");
          return;
        }
        d.el.classList.remove("mob-off");
        d.el.classList.add("mob-focus", "lit");
        const cx = S.w * 0.5;
        const sibs = MODULES[d.mi].feeds.length;
        const idx = dbs.filter((x) => x.mi === d.mi).indexOf(d);
        d.x = cx + (idx - (sibs - 1) / 2) * 76;
        d.y = mh * 0.06;
        return;
      }
      d.el.classList.remove("mob-off", "mob-focus");
      const n = nodes[d.mi];
      let dx = n.x - (S.core.x + S.core.px);
      let dy = n.y - (S.core.y + S.core.py);
      const L = Math.hypot(dx, dy) || 1;
      dx /= L; dy /= L;
      const ang = Math.atan2(dy, dx) + d.spread * 0.95;
      const dist = 152;
      d.x = n.x + Math.cos(ang) * dist;
      d.y = n.y + Math.sin(ang) * dist;
    });
  }

  function buildP() {
    buildEdges();
    S.streams.length = 0;
    const area = S.w * (S.mobile ? S.mapH : S.h);
    const cnt = reduce
      ? (S.mobile ? 100 : 360)
      : Math.min(S.mobile ? 280 : 950, Math.max(S.mobile ? 180 : 620, (area / 1500) | 0));
    const pool = S.edges.filter(edgeVisible);
    const use = pool.length ? pool : S.edges;
    for (let i = 0; i < cnt; i++) {
      const e = use[i % use.length];
      S.streams.push({
        e, lane: i % 9, p: Math.random(),
        sp: (reduce ? 0 : mix(0.00013, 0.00045, Math.random())) * (e.db ? 1 : (i % 2 ? 1 : -1)),
        r: mix(0.7, 2.5, Math.random()) * (e.ring ? 0.78 : (e.db ? 0.7 : 1)),
        phase: Math.random() * TAU,
        flick: mix(0.55, 1.6, Math.random()),
        warm: Math.random(),
        tail: mix(0.025, 0.08, Math.random())
      });
    }
    S.dust.length = 0;
    const dc = reduce ? (S.mobile ? 40 : 70) : (S.mobile ? 90 : 220);
    const dh = S.mobile ? S.mapH : S.h;
    for (let i = 0; i < dc; i++) {
      S.dust.push({
        x: Math.random() * S.w,
        y: Math.random() * dh,
        vx: mix(-0.05, 0.05, Math.random()),
        vy: mix(-0.04, 0.04, Math.random()),
        r: mix(0.35, 1.2, Math.random()),
        a: mix(0.05, 0.16, Math.random()),
        phase: Math.random() * TAU
      });
    }
  }

  function curve(e, lane, time) {
    const p0 = pt(e.a);
    const p3 = pt(e.b);
    const dx = p3.x - p0.x;
    const dy = p3.y - p0.y;
    const L = Math.hypot(dx, dy) || 1;
    const nx = -dy / L;
    const ny = dx / L;
    const wave = Math.sin(time * 0.0011 + e.seed + lane * 0.7);
    const baseBow = e.ring ? 24 : (e.db ? 6 : 0);
    const bow = (lane - 4) * 6 + wave * (e.db ? 6 : 15) + baseBow;
    const nc = 0.34 + 0.04 * Math.sin(e.seed + time * 0.0007);
    return [
      p0,
      { x: p0.x + dx * nc + nx * (40 + bow), y: p0.y + dy * nc + ny * (40 + bow) },
      { x: p0.x + dx * 0.72 - nx * (28 - bow * 0.35), y: p0.y + dy * 0.72 - ny * (28 - bow * 0.35) },
      p3
    ];
  }

  function forces(dt) {
    if (S.mobile) {
      layoutMobile(S.mapH);
      return;
    }
    for (const n of nodes) {
      n.vx += (n.tx - n.x) * 0.08 * dt;
      n.vy += (n.ty - n.y) * 0.08 * dt;
      const dxp = n.x - S.ptr.sx;
      const dyp = n.y - S.ptr.sy;
      const dp = Math.hypot(dxp, dyp);
      if (dp < 180) {
        const push = (1 - dp / 180) * S.ptr.heat * 1.75;
        n.vx += (dxp / (dp + 1)) * push;
        n.vy += (dyp / (dp + 1)) * push;
      }
    }
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        const dx = b.x - a.x, dy = b.y - a.y;
        const d = Math.hypot(dx, dy) || 1;
        if (d < 150) {
          const k = ((150 - d) / d) * 0.013 * dt;
          a.vx -= dx * k; a.vy -= dy * k;
          b.vx += dx * k; b.vy += dy * k;
        }
      }
    }
    for (const n of nodes) {
      n.vx *= Math.pow(0.84, dt);
      n.vy *= Math.pow(0.84, dt);
      n.x += n.vx * dt;
      n.y += n.vy * dt;
    }
  }

  function applyProximity() {
    const reach = 200;
    nodes.forEach((n) => {
      const d = Math.hypot(n.x - S.ptr.sx, n.y - S.ptr.sy);
      const lift = clamp(1 - d / reach, 0, 1) * S.ptr.heat;
      n.el.style.setProperty("--lift", lift.toFixed(3));
      const near = lift > 0.08;
      n.el.classList.toggle("near", near);
      n.el.style.zIndex = near ? 5 : 2;
    });
    dbs.forEach((d) => {
      const dpx = Math.hypot(d.x - S.ptr.sx, d.y - S.ptr.sy);
      const lift = clamp(1 - dpx / (reach * 0.85), 0, 1) * S.ptr.heat;
      d.el.style.setProperty("--lift", lift.toFixed(3));
      const near = lift > 0.08;
      d.el.classList.toggle("near", near);
      d.el.style.zIndex = near || d.el.classList.contains("sel") ? 4 : 1;
    });
  }

  function draw(now, dt) {
    const ch = S.mobile ? S.mapH : S.h;
    ctx.fillStyle = "#0B1017";
    ctx.fillRect(0, 0, S.w, ch);
    if (S.bg) { ctx.fillStyle = S.bg; ctx.fillRect(0, 0, S.w, ch); }

    placeDBs();

    ctx.save();
    ctx.globalCompositeOperation = "lighter";
    for (const d of S.dust) {
      if (!reduce) {
        d.x += d.vx * dt;
        d.y += d.vy * dt;
        if (d.x < -10) d.x = S.w + 10;
        if (d.x > S.w + 10) d.x = -10;
        if (d.y < -10) d.y = ch + 10;
        if (d.y > ch + 10) d.y = -10;
      }
      const alpha = d.a * (0.55 + 0.45 * Math.sin(now * 0.001 + d.phase));
      ctx.fillStyle = rgba(TEAL, alpha);
      ctx.beginPath();
      ctx.arc(d.x, d.y, d.r, 0, TAU);
      ctx.fill();
    }
    ctx.restore();

    ctx.save();
    ctx.globalCompositeOperation = "lighter";
    ctx.lineCap = "round";
    for (const e of S.edges) {
      if (!edgeVisible(e)) continue;
      const act = edgeHot(e);
      for (let lane = 0; lane < 2; lane++) {
        const c = curve(e, lane + 3, now);
        const al = (0.055 + 0.03 * Math.sin(now * 0.0012 + e.seed + lane)) * act * (e.ring ? 0.65 : (e.db ? 0.7 : 1));
        ctx.strokeStyle = (e.ring || e.db || e.web) ? rgba(AMBER, al) : rgba(TEAL, al);
        ctx.lineWidth = e.ring ? 0.8 : (e.db ? 0.7 : 1);
        ctx.beginPath();
        ctx.moveTo(c[0].x, c[0].y);
        ctx.bezierCurveTo(c[1].x, c[1].y, c[2].x, c[2].y, c[3].x, c[3].y);
        ctx.stroke();
      }
    }
    ctx.restore();

    ctx.save();
    ctx.globalCompositeOperation = "lighter";
    for (const s of S.streams) {
      if (!edgeVisible(s.e)) continue;
      if (!reduce) s.p = (s.p + s.sp * dt * 16.67 + 1) % 1;
      const act = edgeHot(s.e);
      if (act < 0.12) continue;
      const t = ease3(s.p);
      const c = curve(s.e, s.lane, now);
      const P = bez(c[0], c[1], c[2], c[3], t);
      const dpt = Math.hypot(P.x - S.ptr.sx, P.y - S.ptr.sy);
      const heat = dpt < 140 ? (1 - dpt / 140) * S.ptr.heat : 0;
      const pulse = 0.68 + 0.32 * Math.sin(now * 0.004 * s.flick + s.phase);
      const np = 0.75 + 0.25 * Math.sin(now * 0.002 + s.e.seed);
      const al = clamp(((0.24 + 0.5 * pulse) * np + heat * 0.7) * act, 0, 1);
      const spr = (s.e.db || s.e.web) ? SPR.amber : (s.warm > 0.8 ? SPR.amber : SPR.teal);
      const r = s.r * (1 + heat * 1.6) * (reduce ? 1.3 : 1);
      const d = r * 7;
      ctx.globalAlpha = al;
      ctx.drawImage(spr, P.x - d * 0.5, P.y - d * 0.5, d, d);
    }
    ctx.globalAlpha = 1;
    ctx.restore();

    const cx = S.core.x + S.core.px;
    const cy = S.core.y + S.core.py;
    const pl = 0.5 + 0.5 * Math.sin(now * 0.0018);
    const rr = S.core.r;
    const R = rr * 4.6 * (1 + pl * 0.05);
    const cg = ctx.createRadialGradient(cx, cy, rr * 0.3, cx, cy, R);
    cg.addColorStop(0, "rgba(230, 255, 250, 0.55)");
    cg.addColorStop(0.08, "rgba(120, 210, 195, 0.32)");
    cg.addColorStop(0.2, "rgba(61, 184, 169, 0.19)");
    cg.addColorStop(0.38, "rgba(26, 138, 125, 0.1)");
    cg.addColorStop(0.62, "rgba(26, 138, 125, 0.035)");
    cg.addColorStop(1, "rgba(26, 138, 125, 0)");
    ctx.save();
    ctx.globalCompositeOperation = "lighter";
    ctx.fillStyle = cg;
    ctx.beginPath();
    ctx.arc(cx, cy, R, 0, TAU);
    ctx.fill();
    ctx.restore();

    coreEl.style.transform = `translate(${cx}px,${cy}px) translate(-50%,-50%)`;
    nodes.forEach((n) => {
      n.el.style.transform = `translate(${n.x}px,${n.y}px) translate(-50%,-50%)`;
    });
    dbs.forEach((d) => {
      d.el.style.transform = `translate(${d.x}px,${d.y}px) translate(-50%,-50%)`;
    });
    applyProximity();
  }

  function frame(now) {
    if (!S.last) S.last = now;
    const dt = Math.min(42, now - S.last) / 16.67;
    S.last = now;
    S.ptr.sx += (S.ptr.x - S.ptr.sx) * 0.12;
    S.ptr.sy += (S.ptr.y - S.ptr.sy) * 0.12;
    S.ptr.heat += ((S.ptr.active ? 1 : 0) - S.ptr.heat) * 0.045;
    if (S.mobile) {
      S.core.px = 0;
      S.core.py = 0;
    } else {
      S.core.px += (((S.ptr.active ? S.ptr.sx : S.core.x) - S.core.x) * 0.018 - S.core.px) * 0.05;
      S.core.py += (((S.ptr.active ? S.ptr.sy : S.core.y) - S.core.y) * 0.018 - S.core.py) * 0.05;
    }
    forces(dt);
    draw(now, dt);
    requestAnimationFrame(frame);
  }

  addEventListener("resize", resize, { passive: true });
  addEventListener("pointermove", (e) => {
    S.ptr.x = e.clientX;
    S.ptr.y = e.clientY;
    S.ptr.active = true;
  }, { passive: true });
  addEventListener("pointerleave", () => { S.ptr.active = false; });
  addEventListener("blur", () => { S.ptr.active = false; });

  resize();
  coreEl.style.transform = `translate(${S.core.x}px,${S.core.y}px) translate(-50%,-50%)`;
  if (!reduce) requestAnimationFrame(frame);
  else draw(1800, 0);
})();
</script>
</body>
</html>
