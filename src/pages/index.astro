    },
    {
      key: "content", name: "Content Engine", role: "editorial factory", proof: "validate · humanizer",
      lede: "SEO articles, guides, landing copy. Agent draft, rules, validation, human approval before publish.",
      does: ["MDX generation pipeline", "Duplicate and quality checks", "Brand voice enforcement", "Batch publish workflow"],
      feeds: [
