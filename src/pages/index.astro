      "Claude API": "Claude",
      "Blog MDX": "Blog",
      "Training library": "Library",
      "Call Analytics": "Call QA",
      "Your APIs": "APIs",
      "Your team": "Team"
    };
    if (map[full]) return map[full];
    if (full.length <= 11) return full;
    return full.split(/[\s/]+/).filter(Boolean).map((w) => w[0]).join("").slice(0, 5).toUpperCase();
  }

  const MODULES = [
    {
      key: "seo", name: "SEO + AEO Site", role: "organic acquisition", proof: "1,260+ pages · 2M+ words",
      lede: "Programmatic SEO site factory: area guides, FAQs, investment content. Indexed for Google, ChatGPT, Perplexity.",
      does: ["Publishes at scale from MDX pipeline", "Auto sitemap + IndexNow", "Internal linking graph", "Compounds traffic month over month"],
      feeds: [
        ["Google Search Console", "search", "Queries, clicks, index coverage.", ["Top queries", "Index status"]],
        ["MDX content repo", "pages", "Articles, guides, landing pages.", ["New URLs", "Content updates"]],
        ["IndexNow / Bing", "ping", "Fast re-crawl after publish.", ["Submitted URLs"]]
      ]
    },
    {
      key: "bot", name: "AI Lead Qualification", role: "24/7 response", proof: "10 sec · chat + voice",
      lede: "Qualifies inbound leads on WhatsApp, Telegram, web chat. Budget, timeline, intent. Routes hot leads to the right person.",
      does: ["Replies in under 10 seconds", "Qualifies budget and timeline", "Hands off to human when ready", "Never misses inbound traffic"],
      feeds: [
        ["WhatsApp / Telegram", "channels", "Where leads message first.", ["Conversation history"]],
        ["Qualification script", "rules", "Questions and scoring logic.", ["Score + tags"]],
        ["Kommo CRM", "handoff", "Creates and updates deals.", ["Deal stage", "Owner routing"]]
      ]
    },
    {
      key: "crm", name: "CRM Automation", role: "pipeline ops", proof: "Kommo · multi-pipeline",
      lede: "Automates deal stages, tags, assignments, follow-ups. Human stays in control on high-value steps.",
      does: ["Auto-tags and routes leads", "Webhook integrations", "Stage rules and reminders", "Single source for sales ops"],
      feeds: [
        ["Kommo API", "crm", "Deals, contacts, pipelines.", ["Stage changes"]],
        ["Webhooks", "events", "Form submits, bot events, site leads.", ["New lead payloads"]],
        ["Broker roster", "routing", "Who owns which segment.", ["Assignment rules"]]
      ]
    },
    {
      key: "calls", name: "Call Analytics", role: "quality control", proof: "Zoom · call review",
      lede: "Captures call context, summaries, next steps. Surfaces gaps in scripts and follow-up.",
      does: ["Summarizes calls and meetings", "Flags missed follow-ups", "Feeds CRM with notes", "Supports QA workflows"],
      feeds: [
        ["Call recordings", "audio", "Stored conversations.", ["Transcripts"]],
        ["Playbooks", "standard", "Scripts and checklists.", ["Compliance checks"]],
        ["Zoom / telephony", "source", "New sessions to process.", ["Metadata"]]
      ]
    },
    {
      key: "report", name: "Reporting Engine", role: "visibility", proof: "GSC + GA4 + Kommo",
      lede: "Live dashboards: organic, conversions, leads by source and broker. One screen for decisions.",
      does: ["Pulls GSC + GA4 + CRM", "Weekly exec snapshots", "Highlights anomalies", "Export for stakeholders"],
      feeds: [
        ["GA4", "analytics", "Sessions, goals, landing pages.", ["Conversion paths"]],
        ["GSC", "organic", "Queries and pages.", ["Traffic trends"]],
        ["Kommo", "leads", "Pipeline and source attribution.", ["Lead counts"]]
