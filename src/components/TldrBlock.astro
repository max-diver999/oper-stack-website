---
interface Props {
  text: string;
}

const { text } = Astro.props;
---
<aside class="tldr-block" itemprop="abstract">
  <div class="tldr-label">Key Takeaway</div>
  <p>{text}</p>
</aside>

<style>
  .tldr-block {
    border-left: 4px solid var(--color-teal-500, #4a9590);
    background: linear-gradient(135deg, #f0faf8 0%, #faf8f4 100%);
    border-radius: 0 12px 12px 0;
    padding: 16px 20px;
    margin: 0 0 24px 0;
    font-size: 15px;
    line-height: 1.65;
    color: #2c2c2c;
  }
  .tldr-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-teal-600, #3d7f7a);
    margin-bottom: 6px;
  }
  .tldr-block p {
    margin: 0;
  }
</style>
